{
  "name": "@peiyanlu/electron-ipc",
  "description": "A personal style Electron tool library.",
  "version": "1.0.10",
  "type": "module",
  "license": "MIT",
  "private": false,
  "scripts": {
    "dev": "tsdown -w",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "prepublish": "tsdown",
    "release": "release"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./backend": {
      "import": "./dist/ElectronBackend.js",
      "types": "./dist/ElectronBackend.d.ts"
    },
    "./preload": {
      "import": "./dist/ElectronPreload.js",
      "types": "./dist/ElectronPreload.d.ts"
    },
    "./frontend": {
      "import": "./dist/ElectronFrontend.js",
      "types": "./dist/ElectronFrontend.d.ts"
    }
  },
  "devDependencies": {
    "@peiyanlu/release": "^0.0.7",
    "@peiyanlu/ts-utils": "^0.0.5",
    "@types/node": "^25.5.2",
    "electron": "^41",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "electron": "^41"
  },
  "author": {
    "name": "YanluPei",
    "email": "peiyanlu@vip.qq.com"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:peiyanlu/electron-ipc.git"
  },
  "homepage": "https://github.com/peiyanlu/electron-ipc",
  "bugs": {
    "url": "https://github.com/peiyanlu/electron-ipc/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "typescript",
    "electron"
  ]
}
