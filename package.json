{
  "name": "@peiyanlu/electron",
  "description": "Utilities and tools for building Electron apps with clear separation between main, preload, and renderer processes.",
  "version": "1.0.11",
  "type": "module",
  "license": "MIT",
  "private": false,
  "scripts": {
    "dev": "tsdown -w",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "prepublish": "tsdown",
    "release": "release"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./backend": {
      "types": "./dist/backend.d.ts",
      "import": "./dist/backend.js"
    },
    "./preload": {
      "types": "./dist/preload.d.ts",
      "import": "./dist/preload.js"
    },
    "./frontend": {
      "types": "./dist/frontend.d.ts",
      "import": "./dist/frontend.js"
    }
  },
  "devDependencies": {
    "@peiyanlu/release": "^0.0.12",
    "@peiyanlu/ts-utils": "^0.0.5",
    "@types/node": "^25.6.0",
    "electron": "^41.3.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "electron": "^41"
  },
  "author": {
    "name": "YanluPei",
    "email": "peiyanlu@vip.qq.com"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:peiyanlu/electron.git"
  },
  "homepage": "https://github.com/peiyanlu/electron",
  "bugs": {
    "url": "https://github.com/peiyanlu/electron/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "typescript",
    "electron"
  ]
}
